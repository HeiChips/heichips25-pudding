<?xml version="1.0" encoding="utf-8"?>
<klayout-macro>
 <description>BasicsLib - FEOL contacts, PMOS buffer cap, PMOS cap array</description>
 <version/>
 <category>pymacros</category>
 <prolog/>
 <epilog/>
 <doc/>
 <autorun>true</autorun>
 <autorun-early>false</autorun-early>
 <priority>0</priority>
 <shortcut/>
 <show-in-menu>false</show-in-menu>
 <group-name/>
 <menu-path/>
 <interpreter>python</interpreter>
 <dsl-interpreter-name/>
 <text># -*- coding: utf-8 -*-
import pya


# ── PCell: feol_contact ───────────────────────────────────────────────────────
#
# A single row/column of contacts with an M1 landing bar.
# l and h are in nm (integers = DBU at dbu=0.001 µm).

class feol_contact(pya.PCellDeclarationHelper):

    def __init__(self):
        super().__init__()
        self.param("l",        self.TypeInt,   "contact length (nm)", default=260)
        self.param("h",        self.TypeInt,   "contact height (nm)", default=160)
        self.param("ly_active",self.TypeLayer, "Active (diffusion)",  default=pya.LayerInfo( 1, 0))
        self.param("ly_po",    self.TypeLayer, "Poly (Gate)",         default=pya.LayerInfo( 5, 0))
        self.param("ly_co",    self.TypeLayer, "Contact (CO)",        default=pya.LayerInfo( 6, 0))
        self.param("ly_m1",    self.TypeLayer, "Metal 1",             default=pya.LayerInfo( 8, 0))
        self.param("ly_pimp",  self.TypeLayer, "P+ implant",          default=pya.LayerInfo(14, 0))
        self.param("ly_nwell", self.TypeLayer, "N-Well",              default=pya.LayerInfo(31, 0))
        self.param("ly_pr",    self.TypeLayer, "Placement boundary",  default=pya.LayerInfo(63, 0))

    def display_text_impl(self):
        return f"feol_contact(l={self.l}, h={self.h})"

    def coerce_parameters_impl(self):
        if self.l &lt;= 260: self.l = 260
        if self.h &lt;= 160: self.h = 160

    def produce_impl(self):
        ly_co = self.layout.layer(self.ly_co)
        ly_m1 = self.layout.layer(self.ly_m1)

        contact_size     = 160
        contact_distance = 180
        contact_pitch    = contact_size + contact_distance
        metal1endcap     =  50
        l = self.l
        h = self.h
        n_cuts_x = max(0, (l + contact_distance - 2 * metal1endcap) // contact_pitch)
        n_cuts_y = max(0, (h + contact_distance)                     // contact_pitch)
        xext     = n_cuts_x * contact_pitch - contact_distance
        yext     = n_cuts_y * contact_pitch - contact_distance
        start_x  = (l - xext) // 2
        start_y  = (h - yext) // 2
        for row in range(n_cuts_y):
            for col in range(n_cuts_x):
                xl = start_x + col * contact_pitch
                yb = start_y + row * contact_pitch
                self.cell.shapes(ly_co).insert(
                    pya.Box(xl, yb, xl + contact_size, yb + contact_size))
        self.cell.shapes(ly_m1).insert(pya.Box(0, 0, l, h))


# ── PCell: pmos_buffer_cap ────────────────────────────────────────────────────
#
# Single PMOS gate capacitor.
#   w  = gate width  (µm) — cell x-extent, scales all y-dimensions
#   l  = gate length (µm) — poly/gate-contact x-extent only
#
# All offsets derived by mapping pmosHV$2 through its rot90+mirrorX placement
# (cell_x = y_internal, cell_y = x_internal) for the W=L=8 reference:
#
#  Layer        cell-x                      cell-y
#  ─────────────────────────────────────────────────────────────────────
#  active main  [0,  w]                     [0,  w+0.68]
#  active src   [0,  w]                     [-0.85, -0.55]  outer S/D tie
#  active drn   [0,  w]                     [gate_y1+0.55, gate_y1+0.85]
#  poly  5/0    [gate_x0-0.79, gate_x1+0.11] [gate_y0, gate_y1]  (incl gate arm)
#  poly  5/2    [-0.18, w+0.18]             [gate_y0, gate_y1]  (channel pin only)
#  M1 bus 8/0   [0,  w]                     [-0.44, gate_y1+0.78]
#  M1 pin 8/2   [0,  w]                     [0.07,  w+0.61]
#  pimp  14/0   [-0.40, w+0.40]             [gate_y0-0.52, gate_y1+0.52]
#  nwell 31/0   [-0.62, w+0.62]             [gate_y0-1.47, gate_y1+1.47]
#  dnwell 44/0  same as nwell
#  gate cont 40 [0, 0.30]                   [gate_y1+0.04, gate_y1+0.34]
#  dev marker 51[−0.18, w+0.18]             [gate_y0, gate_y1]
#
#  gate_x0 = gate_y0 = 0.34
#
#  FEOL contact bars (feol_contact pcell, length = w*1000 nm, height = 160 nm):
#    source  at (0,            -0.44)          rot=0
#    drain   at (0,            gate_y1+0.62)   rot=0
#    gate-L  at (gate_x0-0.72, gate_y0)        rot=90, mirrorX
#    gate-R  at (gate_x1-0.12, gate_y0)        rot=90, mirrorX

class pmos_buffer_cap(pya.PCellDeclarationHelper):

    def __init__(self):
        super().__init__()
        self.param("w",          self.TypeDouble, "Gate width  w (µm)", default=8.0)
        self.param("l",          self.TypeDouble, "Gate length l (µm)", default=8.0)
        self.param("ly_active",  self.TypeLayer,  "Active (diffusion)", default=pya.LayerInfo( 1, 0))
        self.param("ly_po",      self.TypeLayer,  "Poly (Gate)",        default=pya.LayerInfo( 5, 0))
        self.param("ly_co",      self.TypeLayer,  "Contact (CO)",       default=pya.LayerInfo( 6, 0))
        self.param("ly_m1",      self.TypeLayer,  "Metal 1",            default=pya.LayerInfo( 8, 0))
        self.param("ly_pimp",    self.TypeLayer,  "P+ implant",         default=pya.LayerInfo(14, 0))
        self.param("ly_nwell",   self.TypeLayer,  "N-Well",             default=pya.LayerInfo(31, 0))
        self.param("ly_dnwell",  self.TypeLayer,  "Deep N-Well",        default=pya.LayerInfo(44, 0))
        self.param("ly_gatecont",self.TypeLayer,  "Gate cont marker",   default=pya.LayerInfo(40, 0))
        self.param("ly_devmark", self.TypeLayer,  "Device marker",      default=pya.LayerInfo(51, 0))
        self.param("ly_polypin", self.TypeLayer,  "Poly pin (5/2)",     default=pya.LayerInfo( 5, 2))
        self.param("ly_m1pin",   self.TypeLayer,  "M1 pin (8/2)",       default=pya.LayerInfo( 8, 2))

    def display_text_impl(self):
        return f"pmos_buffer_cap(w={self.w:.3f}, l={self.l:.3f})"

    def coerce_parameters_impl(self):
        if self.w &lt; 0.5: self.w = 0.5
        if self.l &lt; 0.5: self.l = 0.5

    def produce_impl(self):
        dbu = self.layout.dbu

        def u(um):
            return round(um / dbu)

        def box(lyr, x1, y1, x2, y2):
            self.cell.shapes(lyr).insert(pya.Box(u(x1), u(y1), u(x2), u(y2)))

        def place_feol(ox, oy, l_nm, rot=0, mirror=False):
            pcell_id   = self.layout.pcell_id("FEOL contacts")
            pcell_decl = self.layout.pcell_declaration("FEOL contacts")
            param_map  = {
                "l": l_nm, "h": 160,
                "ly_active": self.ly_active, "ly_po": self.ly_po,
                "ly_co":     self.ly_co,     "ly_m1": self.ly_m1,
            }
            params = [param_map.get(p.name, p.default)
                      for p in pcell_decl.get_parameters()]
            pcell_var = self.layout.add_pcell_variant(pcell_id, params)
            self.cell.insert(pya.CellInstArray(
                pcell_var, pya.CplxTrans(1.0, rot, mirror, u(ox), u(oy))))

        # resolve layers
        ly_active   = self.layout.layer(self.ly_active)
        ly_po       = self.layout.layer(self.ly_po)
        ly_polypin  = self.layout.layer(self.ly_polypin)
        ly_m1       = self.layout.layer(self.ly_m1)
        ly_m1pin    = self.layout.layer(self.ly_m1pin)
        ly_pimp     = self.layout.layer(self.ly_pimp)
        ly_nwell    = self.layout.layer(self.ly_nwell)
        ly_dnwell   = self.layout.layer(self.ly_dnwell)
        ly_gatecont = self.layout.layer(self.ly_gatecont)
        ly_devmark  = self.layout.layer(self.ly_devmark)

        w = self.w
        l = self.l

        # fixed offsets (µm)
        gate_x0    = 0.34
        gate_y0    = 0.34
        sd_m1_ext  = 0.78   # gate_y edge → far  edge of S/D M1
        sd_gap     = 0.62   # gate_y edge → near edge of S/D M1
        active_ext = 0.85   # gate_y edge → outer tie active edge
        active_h   = 0.30   # tie active stripe height
        poly_ol    = 0.79   # poly overhang left  of gate_x0 (includes gate arm)
        poly_or    = 0.11   # poly overhang right of gate_x1
        poly_ch    = 0.18   # channel poly overhang beyond active edge in x
        gc_inner   = 0.12   # gate contact bar overlap inside gate_x edge
        gc_outer   = 0.60   # gate contact bar extension outside gate_x edge
        nw_x_ext   = 0.62
        nw_y_ext   = 1.47
        pimp_x_ext = 0.40
        pimp_y_ext = 0.52

        gate_x1 = gate_x0 + l
        gate_y1 = gate_y0 + w

        # ── active ───────────────────────────────────────────────────────
        # main: covers full gate + S/D contact area
        box(ly_active,  0,   0,
                        w,   w + 0.68)

        # outer tie-down S/D contact stripes
        box(ly_active,  0,   gate_y0 - active_ext,
                        w,   gate_y0 - active_ext + active_h)   # source

        box(ly_active,  0,   gate_y1 + active_ext - active_h,
                        w,   gate_y1 + active_ext)               # drain

        # ── poly ─────────────────────────────────────────────────────────
        # drawing layer: full gate arm width
        box(ly_po,      gate_x0 - poly_ol,   gate_y0,
                        gate_x1 + poly_or,    gate_y1)

        # pin layer: channel region only (no gate arm)
        box(ly_polypin, -poly_ch,             gate_y0,
                         w + poly_ch,          gate_y1)

        # ── M1 ───────────────────────────────────────────────────────────
        # S/D bus
        box(ly_m1,      0,   gate_y0 - sd_m1_ext,
                        w,   gate_y1 + sd_m1_ext)

        # pin markers (from pmosHV S/D contact strips)
        box(ly_m1pin,   0,   0.07,
                        w,   w + 0.61)

        # ── nwell / deep nwell ────────────────────────────────────────────
        box(ly_nwell,  -nw_x_ext,    gate_y0 - nw_y_ext,
                        w + nw_x_ext, gate_y1 + nw_y_ext)

        box(ly_dnwell, -nw_x_ext,    gate_y0 - nw_y_ext,
                        w + nw_x_ext, gate_y1 + nw_y_ext)

        # ── pimp ─────────────────────────────────────────────────────────
        box(ly_pimp,   -pimp_x_ext,    gate_y0 - pimp_y_ext,
                        w + pimp_x_ext, gate_y1 + pimp_y_ext)

        # ── gate contact marker (layer 40) ────────────────────────────────
        box(ly_gatecont, 0.00,  gate_y1 + 0.04,
                         0.30,  gate_y1 + 0.34)

        # ── device marker (layer 51) ──────────────────────────────────────
        box(ly_devmark, -poly_ch,   gate_y0,
                         w + poly_ch, gate_y1)

        # ── FEOL contact bars ─────────────────────────────────────────────
        w_nm = round(w * 1000)
        place_feol(0,                              gate_y0 - sd_m1_ext, w_nm)           # source
        place_feol(0,                              gate_y1 + sd_gap,    w_nm)           # drain
        place_feol(gate_x0 - gc_outer - gc_inner,  gate_y0, w_nm, rot=90, mirror=True)  # gate L
        place_feol(gate_x1 - gc_inner,             gate_y0, w_nm, rot=90, mirror=True)  # gate R


# ── PCell: pmos_cap_array ─────────────────────────────────────────────────────
#
# 4 vertically stacked pmos_buffer_cap cells positioned within the dacbuffer
# wire frame.
#
# Parameter:
#   w  gate width of each sub-cap (µm) = cell x-extent = gate length (square gate)
#      Cell height = w + 1.70 µm.
#
# Wire-frame positions (dacbuffer, µm):
#   Iout M1  centre=13.095  hw=0.350  top=13.445
#   Top VSS  centre=25.325  hw=0.865  bot=24.460
#
# Design rules from reference placement:
#   m1_spacing     = 0.28   M1 min spacing
#   nwell_spacing  = 3.105  distance x=0 to cap nwell left edge
#   nwell_ext_left = 0.62   cap nwell left overhang of cell origin
#   cap_m1_bot_ext = 0.44   cap M1 bottom below cell y-origin
#
# x_origin = 3.725,  y_base = 14.165,  pitch = w + 1.70

class pmos_cap_array(pya.PCellDeclarationHelper):

    def __init__(self):
        super().__init__()
        self.param("w",          self.TypeDouble, "Gate width of each sub-cap (µm)", default=2.0)
        self.param("ly_active",  self.TypeLayer,  "Active (diffusion)", default=pya.LayerInfo( 1, 0))
        self.param("ly_po",      self.TypeLayer,  "Poly (Gate)",        default=pya.LayerInfo( 5, 0))
        self.param("ly_co",      self.TypeLayer,  "Contact (CO)",       default=pya.LayerInfo( 6, 0))
        self.param("ly_m1",      self.TypeLayer,  "Metal 1",            default=pya.LayerInfo( 8, 0))
        self.param("ly_pimp",    self.TypeLayer,  "P+ implant",         default=pya.LayerInfo(14, 0))
        self.param("ly_nwell",   self.TypeLayer,  "N-Well",             default=pya.LayerInfo(31, 0))
        self.param("ly_dnwell",  self.TypeLayer,  "Deep N-Well",        default=pya.LayerInfo(44, 0))
        self.param("ly_gatecont",self.TypeLayer,  "Gate cont marker",   default=pya.LayerInfo(40, 0))
        self.param("ly_devmark", self.TypeLayer,  "Device marker",      default=pya.LayerInfo(51, 0))
        self.param("ly_polypin", self.TypeLayer,  "Poly pin (5/2)",     default=pya.LayerInfo( 5, 2))
        self.param("ly_m1pin",   self.TypeLayer,  "M1 pin (8/2)",       default=pya.LayerInfo( 8, 2))

    def display_text_impl(self):
        return f"pmos_cap_array(w={self.w:.3f})"

    def coerce_parameters_impl(self):
        if self.w &lt; 0.5: self.w = 0.5

    def produce_impl(self):
        dbu = self.layout.dbu

        def u(um):
            return round(um / dbu)

        def place_cap(ox, oy):
            pcell_id   = self.layout.pcell_id("pmos_buffer_cap")
            pcell_decl = self.layout.pcell_declaration("pmos_buffer_cap")
            param_map  = {
                "w":          self.w,
                "l":          self.w,
                "ly_active":  self.ly_active,
                "ly_po":      self.ly_po,
                "ly_co":      self.ly_co,
                "ly_m1":      self.ly_m1,
                "ly_pimp":    self.ly_pimp,
                "ly_nwell":   self.ly_nwell,
                "ly_dnwell":  self.ly_dnwell,
                "ly_gatecont":self.ly_gatecont,
                "ly_devmark": self.ly_devmark,
                "ly_polypin": self.ly_polypin,
                "ly_m1pin":   self.ly_m1pin,
            }
            params = [param_map.get(p.name, p.default)
                      for p in pcell_decl.get_parameters()]
            pcell_var = self.layout.add_pcell_variant(pcell_id, params)
            self.cell.insert(pya.CellInstArray(
                pcell_var, pya.CplxTrans(1.0, 0, False, u(ox), u(oy))))

        iout_top       = 13.095 + 0.35
        m1_spacing     = 0.28
        nwell_spacing  = 3.105
        nwell_ext_left = 0.62
        cap_m1_bot_ext = 0.44

        x_origin   = nwell_spacing + nwell_ext_left
        y_base     = iout_top + m1_spacing + cap_m1_bot_ext
        cell_pitch = self.w + 1.70

        for n in range(4):
            place_cap(x_origin, y_base + n * cell_pitch)


# ── Library registration ──────────────────────────────────────────────────────

class BasicsLib(pya.Library):
    def __init__(self):
        super().__init__()
        self.description = "BasicsLib – FEOL contacts, PMOS buffer cap, PMOS cap array"
        self.layout().register_pcell("FEOL contacts",   feol_contact())
        self.layout().register_pcell("pmos_buffer_cap", pmos_buffer_cap())
        self.layout().register_pcell("pmos_cap_array",  pmos_cap_array())
        self.register("BasicsLib")

BasicsLib()
</text>
</klayout-macro>